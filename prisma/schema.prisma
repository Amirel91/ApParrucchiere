generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")          // Neon pooler URL (recommended for serverless)
  directUrl = env("DATABASE_URL")          // Falls back to same URL; set DATABASE_DIRECT_URL for separate direct connection
}

// ============ TENANT (Multi-tenancy) ============

model Tenant {
  id              String          @id @default(cuid())
  slug            String          @unique
  businessName    String
  ownerName       String          @default("")
  ownerEmail      String          @default("")
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // ============ BILLING (Nexi XPay) ============
  subscriptionStatus  String       @default("trial")    // trial, active, cancelling, suspended
  planEndDate         DateTime?                         // quando scade il periodo pagato
  nexiCustomerId      String?                           // ID cliente Nexi
  nexiSubscriptionId  String?                           // ID sottoscrizione Nexi
  cancelReason        String?                           // motivo disdetta (anti-churn)
  cancelledAt         DateTime?                         // data della disdetta

  config          BusinessConfig?
  admins          AdminUser[]
}

// ============ SHOP CONFIGURATION (Singleton per tenant) ============

model BusinessConfig {
  id              String         @id @default(cuid())
  tenantId        String         @unique
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shopName        String         @default("Il Mio Negozio")
  shopDescription String         @default("")
  shopPhone       String?
  shopEmail       String?
  shopAddress     String?
  // Activity category chosen during registration
  activityType    String         @default("ALTRO")
  // Lunch break
  lunchBreakEnabled Boolean      @default(false)
  lunchBreakStart   String       @default("12:30")  // "HH:MM"
  lunchBreakEnd     String       @default("14:00")  // "HH:MM"
  // Minimum notice hours: clients cannot book slots closer than X hours from now
  minNoticeHours     Int          @default(1)

  workingHours    WorkingHours[]
  closedDates     ClosedDate[]
  closedPeriods   ClosedPeriod[]
  services        Service[]
  bookings        Booking[]
  resources       Resource[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// ============ SERVICES ============

model Service {
  id              String          @id @default(cuid())
  name            String
  description     String?
  price           Float
  durationMinutes Int
  cleanupMinutes  Int             @default(0)
  bufferMinutes   Int             @default(0)
  active          Boolean         @default(true)
  sortOrder       Int             @default(0)

  configId        String
  config          BusinessConfig  @relation(fields: [configId], references: [id], onDelete: Cascade)

  bookings        BookingService[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([configId, active])
}

// ============ RESOURCES (Postazioni / Collaboratori) ============

model Resource {
  id              String         @id @default(cuid())
  name            String
  active          Boolean        @default(true)
  sortOrder       Int            @default(0)

  configId        String
  config          BusinessConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  bookings        Booking[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([configId, active])
}

// ============ BOOKINGS ============

model Booking {
  id              String          @id @default(cuid())
  customerName    String
  customerSurname String
  customerPhone   String
  customerEmail   String?
  startTime       DateTime
  endTime         DateTime
  totalPrice      Float
  status          String          @default("confirmed") // confirmed, pending, cancelled, blocked

  configId        String
  config          BusinessConfig  @relation(fields: [configId], references: [id], onDelete: Cascade)

  // Nullable for backward compat: existing bookings have no resource
  resourceId      String?
  resource        Resource?       @relation(fields: [resourceId], references: [id], onDelete: SetNull)

  services        BookingService[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([configId, startTime])
  @@index([status, startTime])
}

// ============ BOOKING-SERVICE PIVOT ============

model BookingService {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([bookingId, serviceId])
}

// ============ WORKING HOURS ============

model WorkingHours {
  id        String  @id @default(cuid())
  dayOfWeek Int     // 1=Mon, 2=Tue, ... 7=Sun
  openTime  String  // "09:00"
  closeTime String  // "18:00"
  closed    Boolean @default(false)

  configId  String
  config    BusinessConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, dayOfWeek])
  @@index([configId])
}

// ============ CLOSED DATES ============

model ClosedDate {
  id        String   @id @default(cuid())
  date      String   // "YYYY-MM-DD"
  reason    String   @default("")   // optional reason (e.g. "Ferie", "Malattia", "Festivo")

  configId  String
  config    BusinessConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, date])
  createdAt DateTime @default(now())
}

// ============ CLOSED PERIODS (Vacations / Extraordinary Closures) ============

model ClosedPeriod {
  id        String   @id @default(cuid())
  startDate String   // "YYYY-MM-DD"
  endDate   String   // "YYYY-MM-DD" (inclusive)
  reason    String   @default("")

  configId  String
  config    BusinessConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
  createdAt DateTime @default(now())
}

// ============ ADMIN USER ============

model AdminUser {
  id           String   @id @default(cuid())
  username     String
  password     String   // bcrypt hashed
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, username])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
