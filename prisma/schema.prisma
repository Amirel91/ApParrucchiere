generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============ SHOP CONFIGURATION (Singleton per tenant) ============

model BusinessConfig {
  id              String         @id @default(cuid())
  shopName        String         @default("Il Mio Negozio")
  shopDescription String         @default("")
  shopPhone       String?
  shopEmail       String?
  shopAddress     String?

  workingHours    WorkingHours[]
  services        Service[]
  bookings        Booking[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// ============ SERVICES ============

model Service {
  id              String          @id @default(cuid())
  name            String
  description     String?
  price           Float
  durationMinutes Int
  active          Boolean         @default(true)
  sortOrder       Int             @default(0)

  configId        String
  config          BusinessConfig  @relation(fields: [configId], references: [id], onDelete: Cascade)

  bookings        BookingService[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

// ============ BOOKINGS ============

model Booking {
  id              String          @id @default(cuid())
  customerName    String
  customerSurname String
  customerPhone   String
  customerEmail   String?
  startTime       DateTime
  endTime         DateTime
  totalPrice      Float
  status          String          @default("confirmed") // confirmed, pending, cancelled

  configId        String
  config          BusinessConfig  @relation(fields: [configId], references: [id], onDelete: Cascade)

  services        BookingService[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

// ============ BOOKING-SERVICE PIVOT ============

model BookingService {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([bookingId, serviceId])
}

// ============ WORKING HOURS ============

model WorkingHours {
  id        String  @id @default(cuid())
  dayOfWeek Int     // 1=Mon, 2=Tue, ... 7=Sun
  openTime  String  // "09:00"
  closeTime String  // "18:00"
  closed    Boolean @default(false)

  configId  String
  config    BusinessConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, dayOfWeek])
}

// ============ ADMIN USER ============

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  password     String   // bcrypt hashed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
