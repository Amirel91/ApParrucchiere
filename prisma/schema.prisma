generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ============ TENANT (Multi-tenancy) ============

model Tenant {
  id              String          @id @default(cuid())
  slug            String          @unique
  businessName    String
  ownerName       String          @default("")
  ownerEmail      String          @default("")
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  config          BusinessConfig?
  admins          AdminUser[]
}

// ============ SHOP CONFIGURATION (Singleton per tenant) ============

model BusinessConfig {
  id              String         @id @default(cuid())
  tenantId        String         @unique
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shopName        String         @default("Il Mio Negozio")
  shopDescription String         @default("")
  shopPhone       String?
  shopEmail       String?
  shopAddress     String?
  // Lunch break
  lunchBreakEnabled Boolean      @default(false)
  lunchBreakStart   String       @default("12:30")  // "HH:MM"
  lunchBreakEnd     String       @default("14:00")  // "HH:MM"

  workingHours    WorkingHours[]
  closedDates     ClosedDate[]
  services        Service[]
  bookings        Booking[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// ============ SERVICES ============

model Service {
  id              String          @id @default(cuid())
  name            String
  description     String?
  price           Float
  durationMinutes Int
  cleanupMinutes  Int             @default(0)
  active          Boolean         @default(true)
  sortOrder       Int             @default(0)

  configId        String
  config          BusinessConfig  @relation(fields: [configId], references: [id], onDelete: Cascade)

  bookings        BookingService[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

// ============ BOOKINGS ============

model Booking {
  id              String          @id @default(cuid())
  customerName    String
  customerSurname String
  customerPhone   String
  customerEmail   String?
  startTime       DateTime
  endTime         DateTime
  totalPrice      Float
  status          String          @default("confirmed") // confirmed, pending, cancelled

  configId        String
  config          BusinessConfig  @relation(fields: [configId], references: [id], onDelete: Cascade)

  services        BookingService[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

// ============ BOOKING-SERVICE PIVOT ============

model BookingService {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([bookingId, serviceId])
}

// ============ WORKING HOURS ============

model WorkingHours {
  id        String  @id @default(cuid())
  dayOfWeek Int     // 1=Mon, 2=Tue, ... 7=Sun
  openTime  String  // "09:00"
  closeTime String  // "18:00"
  closed    Boolean @default(false)

  configId  String
  config    BusinessConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, dayOfWeek])
}

// ============ CLOSED DATES ============

model ClosedDate {
  id        String   @id @default(cuid())
  date      String   // "YYYY-MM-DD"
  reason    String   @default("")   // optional reason (e.g. "Ferie", "Malattia", "Festivo")

  configId  String
  config    BusinessConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, date])
  createdAt DateTime @default(now())
}

// ============ ADMIN USER ============

model AdminUser {
  id           String   @id @default(cuid())
  username     String
  password     String   // bcrypt hashed
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, username])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
